---
interface Props {
  title: string;
  excerpt: string;
  category: string;
  date: string;
  slug: string;
}
const { title, excerpt, category, date, slug } = Astro.props;
---

<article class="blog-card card-3d reveal" data-reveal="fade-up">
  <div class="card-3d-inner">
    <div class="card-category">{category}</div>
    <p class="card-date">{date}</p>
    <h3>{title}</h3>
    <p class="card-excerpt">{excerpt}</p>
    <a href={`/blog/${slug}`} class="card-link">Leggi <i class="fas fa-arrow-right"></i></a>
  </div>
</article>

<style is:inline>
  .blog-card {
    background: #1A1A1A;
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 16px;
    padding: 28px 24px;
    transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
  }
  .blog-card:hover {
    border-color: rgba(139,92,246,0.12);
    box-shadow: 0 20px 60px rgba(0,0,0,0.4);
  }
  .card-category {
    display: inline-block;
    font-family: 'Orbitron', monospace;
    font-size: 0.55rem; font-weight: 500;
    color: #8B5CF6;
    letter-spacing: 2px;
    text-transform: uppercase;
    padding: 4px 10px;
    background: rgba(139,92,246,0.1);
    border-radius: 50px;
    margin-bottom: 8px;
  }
  .card-date {
    font-size: 0.75rem;
    color: #6B7280;
    margin-bottom: 12px;
  }
  .blog-card h3 {
    font-family: 'Orbitron', monospace;
    font-size: 0.95rem; font-weight: 600;
    margin-bottom: 10px;
    line-height: 1.4;
  }
  .card-excerpt {
    font-size: 0.82rem;
    color: #9CA3AF;
    line-height: 1.7;
    margin-bottom: 16px;
  }
  .card-link {
    font-size: 0.78rem;
    font-weight: 500;
    color: #8B5CF6;
    display: inline-flex;
    align-items: center;
    gap: 6px;
    transition: gap 0.25s ease;
  }
  .blog-card:hover .card-link { gap: 12px; }
</style>
