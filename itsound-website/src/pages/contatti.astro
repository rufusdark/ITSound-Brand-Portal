---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Contatti">
  <section class="py-24 relative overflow-hidden" style="background: #0A0A0A;">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(139,92,246,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.05) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        Parliamo di Musica
      </div>
      <h1 class="mb-6 hero-fade-in">Contattaci</h1>
      <p class="text-lg text-gray-light max-w-2xl hero-fade-in hero-fade-in-delay-1">
        Hai un progetto musicale? Vuoi inviarci un demo? Raccontaci la tua idea.
        Ti rispondiamo entro 24 ore.
      </p>
    </div>
  </section>

  <section class="py-16 section-reveal" style="background: #141414;">
    <div class="container-custom">
      <div class="grid md:grid-cols-2 gap-16">
        <!-- Form -->
        <div class="reveal" data-reveal="fade-left">
          <h3 class="text-xl font-display font-semibold mb-8">Inviaci il tuo Demo</h3>
          <form class="space-y-6" id="contactForm">
            <div class="grid grid-cols-2 gap-4">
              <div>
                <label class="block text-sm text-gray-light mb-2">Nome *</label>
                <input type="text" required class="input w-full" placeholder="Il tuo nome" />
              </div>
              <div>
                <label class="block text-sm text-gray-light mb-2">Cognome</label>
                <input type="text" class="input w-full" placeholder="Il tuo cognome" />
              </div>
            </div>
            <div>
              <label class="block text-sm text-gray-light mb-2">Email *</label>
              <input type="email" required class="input w-full" placeholder="la-tua@email.com" />
            </div>
            <div>
              <label class="block text-sm text-gray-light mb-2">Tipo di Richiesta</label>
              <select class="input w-full">
                <option value="demo">Invio Demo / Track</option>
                <option value="mixing">Mixing & Mastering</option>
                <option value="ghost">Ghost Production</option>
                <option value="placement">Track Placement</option>
                <option value="promotion">Track Promotion</option>
                <option value="social">Social Management</option>
                <option value="design">Graphic Design</option>
                <option value="web">Web Design</option>
                <option value="collaboration">Collaborazione Artistica</option>
                <option value="general">Informazioni Generali</option>
              </select>
            </div>
            <div>
              <label class="block text-sm text-gray-light mb-2">Link alla tua musica</label>
              <input type="url" class="input w-full" placeholder="SoundCloud, Spotify, YouTube..." />
            </div>
            <div>
              <label class="block text-sm text-gray-light mb-2">Messaggio *</label>
              <textarea required rows="6" class="input w-full resize-none" placeholder="Parlaci del tuo progetto..."></textarea>
            </div>
            <div class="border border-dashed border-gray-muted/30 rounded-xl p-8 text-center hover:border-accent/30 transition-colors cursor-pointer">
              <div class="text-3xl text-gray mb-3"><i class="fas fa-cloud-upload-alt"></i></div>
              <p class="text-sm text-gray-light">Trascina qui il tuo file audio</p>
              <p class="text-xs text-gray mt-2">MP3, WAV, AIFF · Max 50MB</p>
              <button type="button" class="btn btn-ghost text-sm mt-4">Seleziona File</button>
            </div>
            <button type="submit" class="btn btn-primary w-full">
              Invia Messaggio <i class="fas fa-paper-plane"></i>
            </button>
          </form>
        </div>

        <!-- Info -->
        <div>
          <h3 class="text-xl font-display font-semibold mb-8 reveal reveal-delay-1">Info & Contatti</h3>
          
          <div class="space-y-8">
            <!-- WhatsApp Direct -->
            <div class="card p-6 card-3d reveal reveal-delay-1" data-reveal="fade-up">
              <div class="card-3d-inner">
              <div class="flex items-center gap-4 mb-4">
                <div class="w-12 h-12 rounded-xl bg-[#25D366]/10 flex items-center justify-center text-2xl">
                  <i class="fab fa-whatsapp" style="color: #25D366;"></i>
                </div>
                <div>
                  <h4 class="font-display text-sm font-semibold">WhatsApp Direct</h4>
                  <p class="text-xs text-gray-light">Risposta in poche ore</p>
                </div>
              </div>
              <a href="https://wa.me/393317834748?text=Ciao%20ITSound%21%20Ho%20una%20domanda%20sui%20vostri%20servizi." target="_blank" class="btn btn-primary w-full" style="background: linear-gradient(135deg, #25D366, #1ebe5a); box-shadow: 0 4px 20px rgba(37,211,102,0.25);">
                <i class="fab fa-whatsapp"></i> Scrivici su WhatsApp
              </a>
            </div>
            </div>

            <!-- Email -->
            <div class="card p-6 card-3d reveal reveal-delay-2" data-reveal="fade-up">
              <div class="card-3d-inner">
              <h4 class="font-display text-sm font-semibold mb-4 flex items-center gap-2">
                <i class="fas fa-envelope text-accent"></i> Email
              </h4>
              <ul class="space-y-3">
                <li>
                  <a href="mailto:m.carbotti@itsound.it" class="text-sm text-gray-light hover:text-accent transition-colors">
                    m.carbotti@itsound.it
                  </a>
                  <p class="text-xs text-gray mt-1">Direzione Artistica</p>
                </li>
                <li>
                  <a href="mailto:labelsubmission@itsound.it" class="text-sm text-gray-light hover:text-accent transition-colors">
                    labelsubmission@itsound.it
                  </a>
                  <p class="text-xs text-gray mt-1">Demo & Submission</p>
                </li>
              </ul>
            </div>
            </div>

            <!-- Social -->
            <div class="card p-6 card-3d reveal reveal-delay-3" data-reveal="fade-up">
              <div class="card-3d-inner">
              <h4 class="font-display text-sm font-semibold mb-4 flex items-center gap-2">
                <i class="fas fa-hashtag text-accent"></i> Social
              </h4>
              <div class="flex gap-3">
                <a href="https://www.instagram.com/it.sound_/" target="_blank" class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-xl text-gray hover:bg-accent hover:text-white transition-all">
                  <i class="fab fa-instagram"></i>
                </a>
                <a href="https://www.facebook.com/profile.php?id=61568625212052" target="_blank" class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-xl text-gray hover:bg-accent hover:text-white transition-all">
                  <i class="fab fa-facebook-f"></i>
                </a>
                <a href="https://open.spotify.com/intl-it/artist/5v5uG6oqevacHrakv2TBfa" target="_blank" class="w-12 h-12 rounded-xl bg-white/5 flex items-center justify-center text-xl text-gray hover:bg-accent hover:text-white transition-all">
                  <i class="fab fa-spotify"></i>
                </a>
              </div>
            </div>
            </div>

            <!-- Territory Badge -->
            <div class="card p-6 card-3d border-accent/10 reveal reveal-delay-4" data-reveal="fade-up">
              <div class="card-3d-inner">
              <div class="flex items-center gap-3">
                <div class="text-2xl">📍</div>
                <div>
                  <p class="text-sm text-white font-semibold">Martina Franca</p>
                  <p class="text-xs text-gray-light">Puglia, Italia</p>
                </div>
              </div>
            </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="py-20 section-reveal" style="background: #0A0A0A;">
    <div class="container-custom max-w-3xl">
      <div class="center-text reveal">
        <div class="section-label">/ FAQ</div>
        <h2 class="section-title">Domande <span class="gradient-text">Frequenti</span></h2>
      </div>
      <div class="space-y-4 mt-12 stagger-children">
        <details class="card p-6 card-3d cursor-pointer group transition-all">
          <div class="card-3d-inner">
          <summary class="font-semibold flex justify-between items-center text-sm font-display">
            Come invio un demo a ITSound?
            <i class="fas fa-chevron-down text-gray group-open:rotate-180 transition-transform"></i>
          </summary>
          <p class="text-gray-light mt-4 text-sm">
            Compila il form qui sopra selezionando "Invio Demo / Track". Puoi includere un link alla tua musica (SoundCloud, Spotify) o caricare direttamente il file audio. Ti rispondiamo entro 48 ore.
          </p>
          </div>
        </details>
        <details class="card p-6 card-3d cursor-pointer group transition-all">
          <div class="card-3d-inner">
          <summary class="font-semibold flex justify-between items-center text-sm font-display">
            Quanto costa un servizio di mixing/mastering?
            <i class="fas fa-chevron-down text-gray group-open:rotate-180 transition-transform"></i>
          </summary>
          <p class="text-gray-light mt-4 text-sm">
            I prezzi variano in base al progetto. Contattaci con i dettagli della tua traccia e ti faremo un preventivo personalizzato. Offriamo pacchetti per EP e album completi.
          </p>
          </div>
        </details>
        <details class="card p-6 card-3d cursor-pointer group transition-all">
          <div class="card-3d-inner">
          <summary class="font-semibold flex justify-between items-center text-sm font-display">
            Fate ghost production per qualsiasi genere?
            <i class="fas fa-chevron-down text-gray group-open:rotate-180 transition-transform"></i>
          </summary>
          <p class="text-gray-light mt-4 text-sm">
            Sì, produciamo in vari generi: Techno, House, Deep House, Ambient, Experimental, EDM e pop. Raccontaci il tuo sound e creiamo qualcosa di unico per te.
          </p>
          </div>
        </details>
        <details class="card p-6 card-3d cursor-pointer group transition-all">
          <div class="card-3d-inner">
          <summary class="font-semibold flex justify-between items-center text-sm font-display">
            ITSound è solo per artisti pugliesi?
            <i class="fas fa-chevron-down text-gray group-open:rotate-180 transition-transform"></i>
          </summary>
          <p class="text-gray-light mt-4 text-sm">
            No! Siamo nati in Puglia ma collaboriamo con artisti da tutta Italia e dal mondo. La musica non ha confini.
          </p>
          </div>
        </details>
      </div>
    </div>
  </section>

  <style is:inline>
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(139,92,246,0.1);
      border: 1px solid rgba(139,92,246,0.2);
      padding: 7px 16px;
      border-radius: 50px;
      font-size: 0.7rem;
      color: #A78BFA;
      font-weight: 500;
      letter-spacing: 0.3px;
      margin-bottom: 28px;
      backdrop-filter: blur(10px);
    }
    .hero-badge .pulse-dot {
      width: 6px; height: 6px;
      background: #06D6A0;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    .card {
      background: #1A1A1A;
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 16px;
      transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .card:hover {
      border-color: rgba(139,92,246,0.12);
      transform: translateY(-4px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    }
    details.card[open] {
      border-color: rgba(139,92,246,0.2);
    }
    details.card summary::-webkit-details-marker {
      display: none;
    }
    details.card summary {
      list-style: none;
    }
  </style>
</Layout>