---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Home">
  <!-- ═══ HERO ═══ -->
  <section class="hero" id="home">
    <div class="hero-overlay"></div>
    <div class="hero-glow"></div>
    <div class="hero-glow-2"></div>
    <div class="hero-watermark" aria-hidden="true">IT</div>
    
    <!-- Waveform Animation -->
    <div class="waveform-container" aria-hidden="true">
      <div class="waveform-bar" style="--delay: 0s; --duration: 1.2s"></div>
      <div class="waveform-bar" style="--delay: 0.1s; --duration: 1.5s"></div>
      <div class="waveform-bar" style="--delay: 0.2s; --duration: 1.0s"></div>
      <div class="waveform-bar" style="--delay: 0.3s; --duration: 1.8s"></div>
      <div class="waveform-bar" style="--delay: 0.4s; --duration: 1.3s"></div>
      <div class="waveform-bar" style="--delay: 0.5s; --duration: 0.9s"></div>
      <div class="waveform-bar" style="--delay: 0.6s; --duration: 1.6s"></div>
      <div class="waveform-bar" style="--delay: 0.7s; --duration: 1.1s"></div>
      <div class="waveform-bar" style="--delay: 0.8s; --duration: 1.4s"></div>
      <div class="waveform-bar" style="--delay: 0.9s; --duration: 1.7s"></div>
      <div class="waveform-bar" style="--delay: 1.0s; --duration: 1.2s"></div>
      <div class="waveform-bar" style="--delay: 1.1s; --duration: 0.8s"></div>
      <div class="waveform-bar" style="--delay: 1.2s; --duration: 1.5s"></div>
      <div class="waveform-bar" style="--delay: 1.3s; --duration: 1.9s"></div>
      <div class="waveform-bar" style="--delay: 1.4s; --duration: 1.0s"></div>
      <div class="waveform-bar" style="--delay: 1.5s; --duration: 1.3s"></div>
      <div class="waveform-bar" style="--delay: 1.6s; --duration: 1.6s"></div>
      <div class="waveform-bar" style="--delay: 1.7s; --duration: 0.7s"></div>
      <div class="waveform-bar" style="--delay: 1.8s; --duration: 1.4s"></div>
      <div class="waveform-bar" style="--delay: 1.9s; --duration: 1.1s"></div>
    </div>
    
    <div class="container-custom">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        Record Label — Martina Franca
      </div>
      <h1 class="hero-title glow-text">
        <span class="hero-title-line1">Gli Artisti</span><br />
        <span class="hero-title-line2 gradient-text">in un unico posto</span>
      </h1>
      <p class="hero-subtitle">
        Collaboriamo con DJ, producer e artisti emergenti.<br />
        Da Martina Franca al mondo, un passo alla volta.
      </p>
      <div class="hero-actions">
        <a href="/contatti" class="btn btn-primary">
          Invia il tuo Demo <i class="fas fa-arrow-right"></i>
        </a>
        <a href="/servizi" class="btn btn-secondary">
          <i class="fas fa-music"></i> I Nostri Servizi
        </a>
      </div>
      <div class="hero-stats">
        <div class="hero-stat">
          <div class="num"><span class="text-accent">✦</span> Mixing</div>
          <div class="label">Mastering & Produzione</div>
        </div>
        <div class="hero-stat">
          <div class="num"><span class="text-cyan">✦</span> Promotion</div>
          <div class="label">Track Placement & Social</div>
        </div>
        <div class="hero-stat">
          <div class="num"><span class="text-accent">✦</span> Consulting</div>
          <div class="label">Ghost Production & Design</div>
        </div>
      </div>
    </div>
    <div class="scroll-indicator">
      <span>Scorri</span>
      <div class="scroll-line"></div>
    </div>
  </section>

  <!-- ═══ TRUST BAR ═══ -->
  <div class="trust-bar">
    <div class="trust-track">
      <span><i class="fas fa-check"></i> Mixing & Mastering</span>
      <span><i class="fas fa-check"></i> Ghost Production</span>
      <span><i class="fas fa-check"></i> Track Placement</span>
      <span><i class="fas fa-check"></i> Track Promotion</span>
      <span><i class="fas fa-check"></i> Social Management</span>
      <span><i class="fas fa-check"></i> Graphic Design</span>
      <span><i class="fas fa-check"></i> Consulting</span>
      <span><i class="fas fa-check"></i> Web Design Musicale</span>
      <span><i class="fas fa-check"></i> Singer Finder</span>
      <span><i class="fas fa-check"></i> Mixing & Mastering</span>
      <span><i class="fas fa-check"></i> Ghost Production</span>
      <span><i class="fas fa-check"></i> Track Placement</span>
      <span><i class="fas fa-check"></i> Track Promotion</span>
      <span><i class="fas fa-check"></i> Social Management</span>
      <span><i class="fas fa-check"></i> Graphic Design</span>
      <span><i class="fas fa-check"></i> Consulting</span>
      <span><i class="fas fa-check"></i> Web Design Musicale</span>
      <span><i class="fas fa-check"></i> Singer Finder</span>
    </div>
  </div>

  <!-- ═══ ABOUT ═══ -->
  <section class="about section-reveal" id="about">
    <div class="container-custom">
      <div class="about-grid">
        <div class="about-visual parallax-bg-wrap" data-reveal="fade-left">
          <div class="parallax-bg">
            <div class="logo-big text-8xl font-display font-bold text-white/10">iT</div>
          </div>
          <div class="accent-frame"></div>
          <div class="territory-badge">
            <span>Dal 2022</span>
            <div class="place">Martina Franca — Puglia</div>
          </div>
        </div>
        <div class="about-content" data-reveal="fade-right">
          <div class="section-label">/ Chi Siamo</div>
          <h2 class="section-title">Una label che <span class="gradient-text">cresce con te</span></h2>
          <p class="section-sub" style="max-width:100%;">
            ITSound nasce a Martina Franca dalla passione di Marco e Andrea per la musica.
            Siamo una record label che collabora con DJ, producer e artisti emergenti,
            offrendo servizi completi: dalla produzione alla promozione.
          </p>
          <div class="stats-row">
            <div class="stat-item">
              <span class="counter text-2xl font-display font-bold text-white" data-target="2022" data-suffix="">0</span>
              <span class="stat-label">Fondazione</span>
            </div>
            <div class="stat-item">
              <span class="counter text-2xl font-display font-bold text-white" data-target="50" data-suffix="+">0</span>
              <span class="stat-label">Tracce Prodotte</span>
            </div>
            <div class="stat-item">
              <span class="counter text-2xl font-display font-bold text-white" data-target="100" data-suffix="%">0</span>
              <span class="stat-label">Passione</span>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ TEAM ═══ -->
  <section class="team section-reveal" id="team">
    <div class="container-custom">
      <div class="center-text">
        <div class="section-label">/ Team</div>
        <h2 class="section-title">Chi c'è dietro <span class="gradient-text">ITSound</span></h2>
        <p class="section-sub">Due ragazzi di Martina Franca con una missione: dare voce ai talenti del territorio.</p>
      </div>
      <div class="team-grid stagger-gsap">
        <div class="team-card card-3d">
          <div class="card-3d-inner">
            <div class="avatar">M</div>
            <h3>Marco Carbotti</h3>
            <div class="role">Founder · Music Producer · DJ</div>
            <p>Produttore techno e fondatore di ITSound. La mente musicale dietro ogni progetto.</p>
            <div class="social-links">
              <a href="https://open.spotify.com/intl-it/artist/5v5uG6oqevacHrakv2TBfa" target="_blank" aria-label="Spotify"><i class="fab fa-spotify"></i></a>
              <a href="https://soundcloud.com/marco-carbotti-dj" target="_blank" aria-label="SoundCloud"><i class="fab fa-soundcloud"></i></a>
              <a href="https://www.instagram.com/marco_carbotti/" target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
            </div>
          </div>
        </div>
        <div class="team-card card-3d">
          <div class="card-3d-inner">
            <div class="avatar">A</div>
            <h3>Andrea Maggi</h3>
            <div class="role">Co-Founder · Social Media · Content</div>
            <p>Social media manager e content creator. Porta ITSound nel mondo digitale ogni giorno.</p>
            <div class="social-links">
              <a href="https://www.instagram.com/andreamaggi27/" target="_blank" aria-label="Instagram"><i class="fab fa-instagram"></i></a>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ RELEASES ═══ -->
  <section class="releases section-reveal" id="releases">
    <div class="container-custom">
      <div class="center-text">
        <div class="section-label">/ Ultime Uscite</div>
        <h2 class="section-title">Ascolta <span class="gradient-text">le nostre tracce</span></h2>
        <p class="section-sub">Le produzioni firmate ITSound e dai nostri artisti.</p>
      </div>
      <div class="releases-grid stagger-gsap">
        <div class="release-card card-3d">
          <div class="card-3d-inner" style="display:flex;gap:20px;align-items:center;">
            <div class="cover" style="background: linear-gradient(135deg, #8B5CF6, #7C3AED);">
              <i class="fas fa-music"></i>
            </div>
            <div class="info">
              <div class="tag">Techno</div>
              <h3>Make You Mine</h3>
              <div class="artist">Marco Carbotti</div>
              <div class="platforms">
                <a href="https://open.spotify.com/intl-it/artist/5v5uG6oqevacHrakv2TBfa" target="_blank" title="Spotify"><i class="fab fa-spotify"></i></a>
                <a href="https://soundcloud.com/marco-carbotti-dj" target="_blank" title="SoundCloud"><i class="fab fa-soundcloud"></i></a>
                <a href="https://www.youtube.com/@Marco_Carbotti" target="_blank" title="YouTube"><i class="fab fa-youtube"></i></a>
              </div>
            </div>
          </div>
        </div>
        <div class="release-card card-3d">
          <div class="card-3d-inner" style="display:flex;gap:20px;align-items:center;">
            <div class="cover" style="background: linear-gradient(135deg, #06D6A0, #8B5CF6);">
              <i class="fas fa-music"></i>
            </div>
            <div class="info">
              <div class="tag">Techno</div>
              <h3>Mr. Saxobeat — Techno Mix</h3>
              <div class="artist">Marco Carbotti</div>
              <div class="platforms">
                <a href="https://open.spotify.com/intl-it/artist/5v5uG6oqevacHrakv2TBfa" target="_blank" title="Spotify"><i class="fab fa-spotify"></i></a>
                <a href="https://soundcloud.com/marco-carbotti-dj" target="_blank" title="SoundCloud"><i class="fab fa-soundcloud"></i></a>
                <a href="https://www.youtube.com/@Marco_Carbotti" target="_blank" title="YouTube"><i class="fab fa-youtube"></i></a>
              </div>
            </div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ SERVICES ═══ -->
  <section class="services section-reveal" id="services">
    <div class="container-custom">
      <div class="center-text">
        <div class="section-label">/ Servizi</div>
        <h2 class="section-title">Cosa <span class="gradient-text">offriamo</span></h2>
        <p class="section-sub">Dalla produzione alla promozione, tutto ciò che serve per far decollare la tua musica.</p>
      </div>
      <div class="services-grid stagger-gsap">
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/01</div>
            <div class="icon-wrap"><i class="fas fa-sliders-h"></i></div>
            <h3>Mixing & Mastering</h3>
            <p>Portiamo il tuo suono al livello successivo. Mixing professionale e mastering per ogni genere.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/02</div>
            <div class="icon-wrap"><i class="fas fa-ghost"></i></div>
            <h3>Ghost Production</h3>
            <p>Beat e produzioni professionali per DJ e artisti. Tracce personalizzate per il tuo sound.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/03</div>
            <div class="icon-wrap"><i class="fas fa-chart-line"></i></div>
            <h3>Track Placement</h3>
            <p>La tua musica sulle playlist giuste. Strategia di posizionamento per massima visibilità.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/04</div>
            <div class="icon-wrap"><i class="fas fa-bullhorn"></i></div>
            <h3>Track Promotion</h3>
            <p>Promuoviamo la tua musica su tutti i canali: social, playlist, blog e radio.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/05</div>
            <div class="icon-wrap"><i class="fas fa-hashtag"></i></div>
            <h3>Social Management</h3>
            <p>Gestiamo la tua presenza social: contenuti, strategia, crescita organica e adv.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
        <div class="service-card card-3d">
          <div class="card-3d-inner">
            <div class="card-num">/06</div>
            <div class="icon-wrap"><i class="fas fa-paint-brush"></i></div>
            <h3>Graphic Design</h3>
            <p>Copertine, visual, logo, brand identity. La tua immagine al primo sguardo.</p>
            <a href="/servizi" class="card-link">Scopri <i class="fas fa-arrow-right"></i></a>
          </div>
        </div>
      </div>
      <div class="services-showall">
        <a href="/servizi" class="btn btn-ghost">Tutti i Servizi <i class="fas fa-arrow-right"></i></a>
      </div>
    </div>
  </section>

  <!-- ═══ TERRITORY ═══ -->
  <section class="territory section-reveal" id="territory">
    <div class="container-custom">
      <div class="center-text">
        <div class="section-label">/ Territorio</div>
        <h2 class="section-title">Dalla <span class="gradient-text">Puglia</span> al mondo</h2>
        <p class="section-sub">Siamo orgogliosi di essere una label nata a Martina Franca, in Valle d'Itria.</p>
      </div>
      <div class="territory-grid stagger-gsap">
        <div class="territory-card card-3d">
          <div class="card-3d-inner">
            <div class="icon">📍</div>
            <h3>Martina Franca</h3>
            <p>Il nostro cuore batte qui, tra i trulli e la Valle d'Itria.</p>
          </div>
        </div>
        <div class="territory-card card-3d">
          <div class="card-3d-inner">
            <div class="icon">🎵</div>
            <h3>Scouting Locale</h3>
            <p>Cerchiamo talenti in tutta la Puglia. Se fai musica, contattaci.</p>
          </div>
        </div>
        <div class="territory-card card-3d">
          <div class="card-3d-inner">
            <div class="icon">🌍</div>
            <h3>Visione Globale</h3>
            <p>Collaboriamo con artisti e label da tutto il mondo.</p>
          </div>
        </div>
        <div class="territory-card card-3d">
          <div class="card-3d-inner">
            <div class="icon">🤝</div>
            <h3>Collaborazioni</h3>
            <p>Locali, eventi, scuole di musica. Costruiamo rete sul territorio.</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- ═══ CTA ═══ -->
  <section class="cta-section section-reveal">
    <div class="container-custom">
      <h2>Hai un progetto musicale?</h2>
      <p>Raccontaci la tua idea. Ti rispondiamo in 24 ore.</p>
      <a href="/contatti" class="btn btn-primary">
        Invia il tuo Demo <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </section>

  <style is:inline>
    /* ═══ HERO ═══ */
    .hero {
      position: relative;
      min-height: 100vh;
      display: flex;
      align-items: center;
      overflow: hidden;
      background: #0A0A0A;
    }
    .hero-overlay {
      position: absolute; inset: 0; z-index: 1;
      background: linear-gradient(135deg, rgba(10,10,10,0.95) 0%, rgba(10,10,10,0.6) 40%, rgba(10,10,10,0.3) 60%, rgba(10,10,10,0.85) 100%);
    }
    .hero-glow {
      position: absolute;
      top: -30%; right: -10%;
      width: 800px; height: 800px;
      background: radial-gradient(circle, rgba(139,92,246,0.06) 0%, transparent 70%);
      z-index: 1;
      pointer-events: none;
      animation: glowPulse 5s ease-in-out infinite;
    }
    .hero-glow-2 {
      position: absolute;
      bottom: -20%; left: -5%;
      width: 500px; height: 500px;
      background: radial-gradient(circle, rgba(6,214,160,0.04) 0%, transparent 70%);
      z-index: 1;
      pointer-events: none;
      animation: glowPulse 7s ease-in-out infinite 1s;
    }
    .hero .container-custom {
      position: relative; z-index: 2;
      width: 100%; padding-top: 80px;
    }
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(139,92,246,0.1);
      border: 1px solid rgba(139,92,246,0.2);
      padding: 7px 16px;
      border-radius: 50px;
      font-size: 0.7rem;
      color: #A78BFA;
      font-weight: 500;
      letter-spacing: 0.3px;
      margin-bottom: 28px;
      backdrop-filter: blur(10px);
    }
    .hero-badge .pulse-dot {
      width: 6px; height: 6px;
      background: #06D6A0;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    .hero-title {
      font-size: clamp(2.4rem, 5vw, 3.8rem);
      line-height: 1.1;
      margin-bottom: 20px;
    }
    .hero-title-line1,
    .hero-title-line2 {
      font-family: 'Orbitron', monospace;
      font-weight: 800;
      letter-spacing: -1px;
    }
    .hero-subtitle {
      font-size: 1.05rem;
      color: rgba(255,255,255,0.45);
      line-height: 1.8;
      margin-bottom: 36px;
      max-width: 520px;
      font-weight: 300;
    }
    .hero-actions {
      display: flex; gap: 16px; flex-wrap: wrap;
    }
    .hero-stats {
      display: flex; gap: 48px;
      margin-top: 60px; padding-top: 32px;
      border-top: 1px solid rgba(255,255,255,0.04);
    }
    .hero-stat .num {
      font-family: 'Orbitron', monospace;
      font-size: 1.2rem; font-weight: 600;
      color: white; line-height: 1;
    }
    .hero-stat .label {
      font-size: 0.72rem;
      color: rgba(255,255,255,0.3);
      margin-top: 4px; letter-spacing: 0.5px;
    }
    .hero-watermark {
      position: absolute;
      right: 3%; bottom: 8%;
      font-family: 'Orbitron', monospace;
      font-size: clamp(6rem, 18vw, 18rem);
      font-weight: 900;
      color: rgba(255,255,255,0.015);
      z-index: 1;
      pointer-events: none;
      line-height: 1;
      animation: watermarkFloat 12s ease-in-out infinite;
      user-select: none;
    }

    /* ─── WAVEFORM ─── */
    .waveform-container {
      position: absolute;
      right: 5%; top: 50%;
      transform: translateY(-50%);
      z-index: 2;
      display: flex;
      gap: 4px;
      align-items: center;
      height: 100px;
      opacity: 0.15;
      pointer-events: none;
    }
    .waveform-bar {
      width: 3px;
      height: 8px;
      background: linear-gradient(to top, #8B5CF6, #A78BFA);
      border-radius: 3px;
      animation: waveform var(--duration, 1s) ease-in-out infinite;
      animation-delay: var(--delay, 0s);
    }

    .scroll-indicator {
      position: absolute;
      bottom: 28px; left: 50%;
      transform: translateX(-50%);
      z-index: 2;
      display: flex; flex-direction: column; align-items: center; gap: 8px;
      opacity: 0.25;
    }
    .scroll-indicator span {
      font-size: 0.55rem;
      letter-spacing: 3px; text-transform: uppercase;
      color: rgba(255,255,255,0.3);
    }
    .scroll-line {
      width: 1px; height: 28px;
      background: linear-gradient(to bottom, rgba(255,255,255,0.15), transparent);
    }

    /* ═══ TRUST BAR ═══ */
    .trust-bar {
      padding: 18px 0;
      background: #141414;
      border-top: 1px solid rgba(255,255,255,0.03);
      border-bottom: 1px solid rgba(255,255,255,0.03);
      overflow: hidden;
    }
    .trust-track span {
      font-size: 0.72rem;
      font-weight: 500;
      color: #4B5563;
      letter-spacing: 1px;
      text-transform: uppercase;
      white-space: nowrap;
      display: flex;
      align-items: center;
      gap: 10px;
    }
    .trust-track span i { color: #8B5CF6; }

    /* ═══ ABOUT ═══ */
    .about { padding: 120px 0; }
    .about-grid {
      display: grid;
      grid-template-columns: 1fr 1fr;
      gap: 80px;
      align-items: center;
    }
    .about-visual {
      position: relative;
      border-radius: 24px;
      overflow: hidden;
      min-height: 460px;
      background: #141414;
      border: 1px solid rgba(255,255,255,0.04);
      display: flex;
      align-items: center;
      justify-content: center;
    }
    .about-visual .accent-frame {
      position: absolute;
      inset: 16px;
      border: 1px solid rgba(139,92,246,0.08);
      border-radius: 16px;
      pointer-events: none;
    }
    .about-visual .territory-badge {
      position: absolute;
      bottom: 24px; left: 24px;
      background: rgba(10,10,10,0.9);
      backdrop-filter: blur(20px);
      padding: 16px 24px;
      border-radius: 16px;
      border: 1px solid rgba(139,92,246,0.1);
    }
    .about-visual .territory-badge span {
      font-family: 'Orbitron', monospace;
      font-size: 0.65rem;
      font-weight: 500;
      color: #8B5CF6;
