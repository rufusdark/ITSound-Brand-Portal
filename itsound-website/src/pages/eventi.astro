---
import Layout from '../layouts/Layout.astro';

const events = [
  {
    date: '15',
    month: 'GIU',
    title: 'Techno Night @ Club Underground',
    location: 'Milano',
    genre: 'Techno · Hard Techno',
    artists: ['Marco Carbotti', 'MC']
  },
  {
    date: '22',
    month: 'GIU',
    title: 'Ambient Session @ Spazio Aperto',
    location: 'Roma',
    genre: 'Ambient · Experimental',
    artists: ['Alessandro Gialli']
  },
  {
    date: '30',
    month: 'GIU',
    title: 'Summer Festival — ITSound Stage',
    location: 'Martina Franca',
    genre: 'Vari',
    artists: ['Marco Carbotti', 'Sara Neri']
  },
  {
    date: '05',
    month: 'LUG',
    title: 'MEI 2026 — Meetup Indipendente',
    location: 'Bologna',
    genre: 'Networking',
    artists: ['ITSound Team']
  },
  {
    date: '12',
    month: 'LUG',
    title: 'Puglia Sounds Festival',
    location: 'Lecce',
    genre: 'Techno · House',
    artists: ['Marco Carbotti']
  },
];
---

<Layout title="Eventi">
  <section class="py-24 relative overflow-hidden" style="background: #0A0A0A;">
    <div class="absolute inset-0 opacity-5">
      <div class="absolute inset-0" style="background-image: linear-gradient(rgba(139,92,246,0.05) 1px, transparent 1px), linear-gradient(90deg, rgba(139,92,246,0.05) 1px, transparent 1px); background-size: 60px 60px;"></div>
    </div>
    <div class="container-custom relative z-10">
      <div class="hero-badge">
        <span class="pulse-dot"></span>
        Calendario
      </div>
      <h1 class="mb-6 hero-fade-in">Prossimi <span class="gradient-text">Eventi</span></h1>
      <p class="text-lg text-gray-light max-w-2xl hero-fade-in hero-fade-in-delay-1">
        Scopri dove trovarci. Date, festival e serate con gli artisti ITSound.
      </p>
    </div>
  </section>

  <section class="py-16 section-reveal" style="background: #141414;">
    <div class="container-custom">
      <div class="space-y-4 stagger-children stagger-gsap">
        {events.map((event) => (
          <div class="event-card card-3d reveal" data-reveal="fade-up">
            <div class="card-3d-inner">
            <div class="event-date">
              <span class="event-day">{event.date}</span>
              <span class="event-month">{event.month}</span>
            </div>
            <div class="event-info">
              <h3>{event.title}</h3>
              <div class="event-meta">
                <span><i class="fas fa-map-pin"></i> {event.location}</span>
                <span class="event-genre">{event.genre}</span>
              </div>
              <div class="event-artists">
                <span class="text-xs text-gray">Con:</span>
                {event.artists.map((a) => (
                  <span class="artist-tag">{a}</span>
                ))}
              </div>
            </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="py-20 text-center section-reveal" style="background: #0A0A0A;">
    <div class="container-custom reveal">
      <div class="section-label">/ Sei un Organizzatore?</div>
      <h2 class="section-title">Vuoi <span class="gradient-text">bookare</span> i nostri artisti?</h2>
      <p class="section-sub mx-auto mt-4 mb-8">
        Contattaci per booking, collaborazioni e festival. Porta il sound ITSound nel tuo evento.
      </p>
      <a href="/contatti" class="btn btn-primary">
        Richiedi Booking <i class="fas fa-arrow-right"></i>
      </a>
    </div>
  </section>

  <style is:inline>
    .hero-badge {
      display: inline-flex; align-items: center; gap: 8px;
      background: rgba(139,92,246,0.1);
      border: 1px solid rgba(139,92,246,0.2);
      padding: 7px 16px;
      border-radius: 50px;
      font-size: 0.7rem; color: #A78BFA;
      font-weight: 500; letter-spacing: 0.3px;
      margin-bottom: 28px; backdrop-filter: blur(10px);
    }
    .hero-badge .pulse-dot {
      width: 6px; height: 6px;
      background: #06D6A0;
      border-radius: 50%;
      animation: pulse 2s ease-in-out infinite;
    }
    .event-card {
      background: #1A1A1A;
      border: 1px solid rgba(255,255,255,0.04);
      border-radius: 16px;
      padding: 24px 28px;
      display: flex;
      gap: 24px;
      align-items: center;
      transition: all 0.5s cubic-bezier(0.25, 0.46, 0.45, 0.94);
    }
    .event-card:hover {
      border-color: rgba(139,92,246,0.12);
      transform: translateY(-3px);
      box-shadow: 0 8px 30px rgba(0,0,0,0.3);
    }
    .event-date {
      display: flex;
      flex-direction: column;
      align-items: center;
      min-width: 70px;
    }
    .event-day {
      font-family: 'Orbitron', monospace;
      font-size: 2rem;
      font-weight: 700;
      color: #8B5CF6;
      line-height: 1;
    }
    .event-month {
      font-size: 0.7rem;
      color: #6B7280;
      text-transform: uppercase;
      letter-spacing: 2px;
      margin-top: 4px;
    }
    .event-info { flex: 1; }
    .event-info h3 {
      font-family: 'Orbitron', monospace;
      font-size: 0.95rem;
      font-weight: 600;
      margin-bottom: 8px;
    }
    .event-meta {
      display: flex;
      gap: 16px;
      flex-wrap: wrap;
      font-size: 0.82rem;
      color: #9CA3AF;
      margin-bottom: 8px;
    }
    .event-meta i { margin-right: 4px; }
    .event-genre {
      padding: 2px 8px;
      background: rgba(139,92,246,0.1);
      border-radius: 50px;
      font-size: 0.7rem;
      color: #A78BFA;
    }
    .event-artists {
      display: flex;
      gap: 6px;
      align-items: center;
      flex-wrap: wrap;
    }
    .artist-tag {
      font-size: 0.75rem;
      padding: 2px 10px;
      background: rgba(255,255,255,0.04);
      border-radius: 50px;
      color: white;
    }
    @media (max-width: 600px) {
      .event-card { flex-direction: column; text-align: center; }
      .event-meta { justify-content: center; }
      .event-artists { justify-content: center; }
    }
  </style>
</Layout>